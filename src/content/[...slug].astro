---
import { getCollection } from 'astro:content';
import CourseLayout from '../../layouts/CourseLayout.astro';

export async function getStaticPaths() {
  const courseEntries = await getCollection('course');
  
  // Sort by week number
  const sortedEntries = courseEntries.sort((a, b) => a.data.week - b.data.week);

  return sortedEntries.map((entry, index) => {
    const prevWeek = index > 0 ? sortedEntries[index - 1] : null;
    const nextWeek = index < sortedEntries.length - 1 ? sortedEntries[index + 1] : null;

    return {
      params: { slug: entry.slug },
      props: { 
        entry,
        prevWeek,
        nextWeek
      },
    };
  });
}

const { entry, prevWeek, nextWeek } = Astro.props;

if (!entry) {
  throw new Error('Course entry not found!');
}

const { Content } = await entry.render();

// Quiz data for each lesson - matches the new beginner course
const quizData = {
  1: {
    question: 'In the "Sea of the Market" analogy, what are YOU as a new trader?',
    options: ['1. A big fish (Institutional Trader)', '2. A small fish (Retail Trader)', '3. The shark'],
    correct: 2
  },
  2: {
    question: 'You buy a Call option at $0.50. The stock rises and your option increases to $1.50. What is your profit on a single contract?',
    options: ['1. $50', '2. $100', '3. $150'],
    correct: 2
  },
  3: {
    question: 'What happens to option premiums the moment an earnings report is released?',
    options: ['1. They go up due to excitement', '2. They stay the same until the next day', '3. They drop due to IV Crush, even if the stock moves correctly'],
    correct: 3
  },
  4: {
    question: 'You have a $10,000 account. Using the 5% Rule, what is the maximum you should risk on a single trade?',
    options: ['1. $100', '2. $500', '3. $1,000'],
    correct: 2
  },
  5: {
    question: 'In #TheStrat, a candle that has a higher LOW and a lower HIGH than the previous candle is called a:',
    options: ['1. Outside Bar (Type 3)', '2. Directional Bar (Type 2)', '3. Inside Bar (Type 1)'],
    correct: 3
  },
  6: {
    question: 'You see a stock rocketing up, but you did not plan a trade for it. You feel FOMO. What is the correct action?',
    options: ['1. Chase the trade immediately, or you will miss out', '2. Wait. There is always another bus coming. Trade your setup, not FOMO', '3. Buy just a small amount to participate'],
    correct: 2
  },
  7: {
    question: 'What is the absolute MINIMUM viable setup for a beginner to start trading (at zero cost)?',
    options: ['1. Premium flow tools and multiple paid services', '2. Webull paper trading account + free TradingView + Saty\'s free indicators', '3. Only a physical journal and a free brokerage'],
    correct: 2
  },
  8: {
    question: 'What is the recommended path forward after completing this course?',
    options: ['1. Fund a large account and start trading immediately', '2. Paper trade for 30 days first, then start small with real money', '3. Find a premium trading room to copy trades from'],
    correct: 2
  }
};

const weekNumber = entry.data.week;
const quiz = quizData[weekNumber] || null;
---

<CourseLayout frontmatter={entry.data}>
  <Content />
  
  {quiz && (
    <div class="quiz-section">
      <h3 class="quiz-title">📝 Lesson {entry.data.week} Assessment</h3>
      <p class="quiz-question"><strong>Question:</strong> {quiz.question}</p>
      
      <div class="quiz-options">
        {quiz.options.map((option, index) => (
          <button 
            class="quiz-option" 
            data-option={index + 1}
            data-correct={quiz.correct}
          >
            {option}
          </button>
        ))}
      </div>
      
      <div class="quiz-feedback" id="quiz-feedback"></div>
    </div>
  )}

  <!-- Navigation -->
  <div class="lesson-navigation">
    {prevWeek ? (
      <a href={`/course/${prevWeek.slug}`} class="nav-btn prev-btn">
        <span class="nav-arrow">←</span>
        <div>
          <div class="nav-label">Previous</div>
          <div class="nav-title">{prevWeek.data.title}</div>
        </div>
      </a>
    ) : (
      <div></div>
    )}
    
    {nextWeek ? (
      <a href={`/course/${nextWeek.slug}`} class="nav-btn next-btn">
        <div>
          <div class="nav-label">Next</div>
          <div class="nav-title">{nextWeek.data.title}</div>
        </div>
        <span class="nav-arrow">→</span>
      </a>
    ) : (
      <a href="/course" class="nav-btn next-btn">
        <div>
          <div class="nav-label">Complete</div>
          <div class="nav-title">Back to Course</div>
        </div>
        <span class="nav-arrow">→</span>
      </a>
    )}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const options = document.querySelectorAll('.quiz-option');
      const feedback = document.getElementById('quiz-feedback');
      
      if (!options.length) return;
      
      options.forEach(option => {
        option.addEventListener('click', function() {
          const selected = parseInt(this.dataset.option);
          const correct = parseInt(this.dataset.correct);
          
          // Remove previous states
          options.forEach(opt => {
            opt.classList.remove('selected', 'correct', 'incorrect');
            opt.disabled = false;
          });
          
          // Mark selected
          this.classList.add('selected');
          
          // Check answer
          if (selected === correct) {
            this.classList.add('correct');
            if (feedback) {
              feedback.innerHTML = '<div class="feedback-correct">✓ Correct! Great job!</div>';
            }
          } else {
            this.classList.add('incorrect');
            // Show correct answer
            options.forEach(opt => {
              if (parseInt(opt.dataset.option) === correct) {
                opt.classList.add('correct');
              }
            });
            if (feedback) {
              feedback.innerHTML = '<div class="feedback-incorrect">✗ Incorrect. The correct answer is highlighted above.</div>';
            }
          }
          
          // Disable all options after answer
          options.forEach(opt => opt.disabled = true);
        });
      });
    });
  </script>

  <style>
    .quiz-section {
      margin-top: 4rem;
      padding-top: 3rem;
      border-top: 2px solid var(--border-color);
    }

    .quiz-title {
      color: var(--accent-primary);
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .quiz-question {
      font-size: 1.125rem;
      margin-bottom: 2rem;
      color: var(--text-primary);
    }

    .quiz-options {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .quiz-option {
      background: var(--bg-secondary);
      border: 2px solid var(--border-color);
      border-radius: 8px;
      padding: 1rem 1.5rem;
      color: var(--text-primary);
      text-align: left;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 1rem;
    }

    .quiz-option:hover:not(:disabled) {
      border-color: var(--accent-primary);
      background: var(--bg-card);
      transform: translateX(8px);
    }

    .quiz-option.correct {
      background: rgba(34, 197, 94, 0.1);
      border-color: rgb(34, 197, 94);
      color: rgb(34, 197, 94);
      font-weight: 600;
    }

    .quiz-option.incorrect {
      background: rgba(239, 68, 68, 0.1);
      border-color: rgb(239, 68, 68);
      color: rgb(239, 68, 68);
    }

    .quiz-option:disabled {
      cursor: not-allowed;
      opacity: 0.9;
    }

    .quiz-feedback {
      min-height: 60px;
      margin-top: 1.5rem;
    }

    .feedback-correct {
      background: rgba(34, 197, 94, 0.1);
      border: 2px solid rgb(34, 197, 94);
      color: rgb(34, 197, 94);
      padding: 1rem;
      border-radius: 8px;
      font-weight: 600;
      text-align: center;
      font-size: 1.125rem;
    }

    .feedback-incorrect {
      background: rgba(239, 68, 68, 0.1);
      border: 2px solid rgb(239, 68, 68);
      color: rgb(239, 68, 68);
      padding: 1rem;
      border-radius: 8px;
      font-weight: 600;
      text-align: center;
      font-size: 1.125rem;
    }

    .lesson-navigation {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-top: 4rem;
      padding-top: 3rem;
      border-top: 2px solid var(--border-color);
    }

    .nav-btn {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.5rem;
      background: var(--bg-secondary);
      border: 2px solid var(--border-color);
      border-radius: 12px;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .nav-btn:hover {
      border-color: var(--accent-primary);
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(108, 99, 255, 0.2);
    }

    .prev-btn {
      justify-content: flex-start;
    }

    .next-btn {
      justify-content: flex-end;
      grid-column: 2;
    }

    .nav-arrow {
      font-size: 1.5rem;
      color: var(--accent-primary);
    }

    .nav-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.25rem;
    }

    .nav-title {
      color: var(--text-primary);
      font-weight: 600;
      font-size: 1rem;
    }

    @media (max-width: 768px) {
      .lesson-navigation {
        grid-template-columns: 1fr;
      }

      .next-btn {
        grid-column: 1;
      }

      .quiz-option:hover:not(:disabled) {
        transform: translateX(4px);
      }
    }
  </style>
</CourseLayout>
