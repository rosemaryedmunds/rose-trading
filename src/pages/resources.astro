---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components'; // This was the missing line
---

<Layout title="Resources">
  <section class="hero">
    <div class="container">
      <h1>Trading Resources</h1>
      <p class="intro">
        Access curated learning materials, helpful tools, and recommended books to accelerate your trading journey.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 900px;">
      
      <div class="resource-dropdown">
        <button class="dropdown-header">
          <span class="dropdown-title">
            <span class="dropdown-icon"><Icon name="lucide:book-open" /></span>
            Learning Resources
          </span>
          <span class="dropdown-arrow">▼</span>
        </button>
        <div class="dropdown-content">
          <div class="resource-grid">
            <div class="resource-section">
              <h3>Beginner Charting</h3>
              <ul class="resource-list">
                <li><a href="https://youtu.be/7UFkfBbGk8s?si=O4Y5aZz7sDRL84B_" target="_blank">Intro to the Market</a></li>
                <li><a href="https://www.youtube.com/playlist?list=PLU9f1fTtAn5rCgq2tCbpaJkEru3bzxF7x" target="_blank">Chart Pattern Course</a></li>
                <li><a href="https://www.youtube.com/playlist?list=PLU9f1fTtAn5r0om7hq7nhRs45kzSBZMcl" target="_blank">Technical Trading Course</a></li>
                <li><a href="https://www.youtube.com/playlist?list=PLU9f1fTtAn5qSOuwkc5PT0STeLF0mW8Ur" target="_blank">Supply & Demand Trading</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="resource-dropdown">
        <button class="dropdown-header">
          <span class="dropdown-title">
            <span class="dropdown-icon"><Icon name="lucide:library" /></span>
            Must Read Books
          </span>
          <span class="dropdown-arrow">▼</span>
        </button>
        <div class="dropdown-content">
          <div class="books-grid">
            <div class="book-item">Trading in the Zone by Mark Douglas</div>
            <div class="book-item">The Best Loser Wins by Tom Hougaard</div>
            <div class="book-item">The Mental Game of Trading by Jared Tendler</div>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  [data-icon] {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--accent-primary);
    display: inline-block;
    vertical-align: middle;
  }
  
  .dropdown-title {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
  }
  
  .hero h1 {
    font-size: 3.5rem;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .resource-dropdown {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .dropdown-header {
    width: 100%;
    padding: 1.5rem 2rem;
    background: none;
    border: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    color: var(--text-primary);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .dropdown-content {
    max-height: 0;
    overflow: hidden;
    padding: 0 2rem;
    transition: max-height 0.3s ease;
  }

  .resource-dropdown.active .dropdown-content {
    max-height: 2000px;
    padding: 0 2rem 2rem 2rem;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.dropdown-header').forEach(header => {
      header.addEventListener('click', function() {
        this.parentElement.classList.toggle('active');
        const arrow = this.querySelector('.dropdown-arrow');
        arrow.style.transform = this.parentElement.classList.contains('active') ? 'rotate(180deg)' : 'rotate(0deg)';
      });
    });
  });
</script>