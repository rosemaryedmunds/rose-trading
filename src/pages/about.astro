---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="About Rose">
  <section class="section">
    <div class="container">
      <h1 style="text-align: center; margin-bottom: 3rem;">About Me</h1>
      
      <div class="about-content">
        <div class="about-image">
          <img src="/rose-photo.jpg" alt="Rose - Trading Analyst" />
        </div>
        
        <div class="about-text">
          <h2 style="color: var(--accent-primary); margin-bottom: 1.5rem;">Hi, I'm Rose! <Icon name="lucide:sparkles" style="display:inline; width:1.5rem;" /></h2>
          
          <p>
            Rose is an IT Trading Analyst for a Fortune 500 company that lives in Houston, Texas.
          </p>
          
          <p>
            Rose started trading in 2020. She mainly focused on options with a main focus on SPX right now.
          </p>
          
          <p>
            Rose likes to use #TheStrat and Market Structure to swing trade and intraday trade.
          </p>
        </div>
      </div>

      <div class="grid grid-3" style="margin-top: 4rem;">
        <div class="card" style="text-align: center;">
          <div class="icon-wrapper"><Icon name="lucide:zap" /></div>
          <h3 style="color: var(--accent-primary); margin-bottom: 0.75rem;">My Approach</h3>
          <p style="margin: 0;">#TheStrat and Market Structure for swing and intraday trading</p>
        </div>
        
        <div class="card" style="text-align: center;">
          <div class="icon-wrapper"><Icon name="lucide:target" /></div>
          <h3 style="color: var(--accent-primary); margin-bottom: 0.75rem;">Main Focus</h3>
          <p style="margin: 0;">SPX Options Trading</p>
        </div>
        
        <div class="card" style="text-align: center;">
          <div class="icon-wrapper"><Icon name="lucide:graduation-cap" /></div>
          <h3 style="color: var(--accent-primary); margin-bottom: 0.75rem;">My Mission</h3>
          <p style="margin: 0;">Teaching technical analysis, risk management, and trading psychology</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ... existing styles ... */
  [data-icon] {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--accent-primary);
    filter: drop-shadow(0 0 8px rgba(108, 99, 255, 0.4));
    margin: 0 auto 1rem;
  }
</style>