---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Morning Brief">
  <main class="brief-container">
    <header>
      <h1>Morning Brief</h1>
      <p id="current-date"></p>
    </header>

    <div id="loading">Scanning markets...</div>
    <div id="error" class="hidden"></div>
    <div id="brief-content" class="hidden">
      </div>
  </main>

  <script>
    async function getBrief() {
      const content = document.getElementById('brief-content');
      const loading = document.getElementById('loading');
      
      try {
        const res = await fetch('/.netlify/functions/morning-brief');
        const data = await res.json();
        
        content.innerHTML = `
          <section class="card">
            <h3>Market Tone</h3>
            <p>${data.market_tone}</p>
          </section>

          <section class="card">
            <h3>Trump Schedule</h3>
            <ul>${data.trump_schedule.map(s => `<li><strong>${s.time}:</strong> ${s.event}</li>`).join('')}</ul>
          </section>

          <div class="grid">
            <section class="card">
              <h3>Gaps</h3>
              <p>🟢 ${data.gaps.ups.join(', ')}</p>
              <p>🔴 ${data.gaps.downs.join(', ')}</p>
            </section>
            
            <section class="card">
              <h3>Econ Calendar</h3>
              <ul>${data.econ_calendar.map(e => `<li>${e.time} - ${e.event} (${e.impact})</li>`).join('')}</ul>
            </section>
          </div>
        `;
        
        loading.classList.add('hidden');
        content.classList.remove('hidden');
      } catch (e) {
        document.getElementById('error').textContent = "Brief failed to load. Check API Key.";
        document.getElementById('error').classList.remove('hidden');
      }
    }

    document.getElementById('current-date').textContent = new Date().toDateString();
    getBrief();
  </script>

  <style>
    .brief-container { max-width: 800px; margin: auto; padding: 2rem; color: #fff; }
    .card { background: #1a1a1a; padding: 1.5rem; border-radius: 8px; margin-bottom: 1rem; border: 1px solid #333; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .hidden { display: none; }
    h3 { color: #6B5ECD; margin-top: 0; }
  </style>
</Layout>