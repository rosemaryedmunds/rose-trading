---
import Layout from '../layouts/Layout.astro';
import StepCard from '../components/StepCard.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Trading Guides">
  <section class="hero">
    <div class="container">
      <h1>Trading Guides</h1>
      <p class="intro">Essential guides to help you prepare for the market, develop a study plan, and maintain a trading journal. [cite: 29]</p>
    </div>
  </section>

  <section class="section" id="preparing">
    <div class="container">
      <h2>Preparing for the Market</h2>
      <p style="max-width: 800px; margin: 0 auto 3rem; text-align: center; color: var(--text-secondary);">
        Follow these 8 essential steps each morning to prepare for your trading day. [cite: 31]
      </p>
      <div class="grid grid-2">
        <StepCard number="01" title="Chart Indices & Futures" description="This will help you find the direction of where the market is going. [cite: 32]" />
        <StepCard number="02" title="Chart Sectors" description="This will help you see which sector this market is moving in and out of. [cite: 33]" />
        <StepCard number="03" title="Chart tickers within sectors" description="Find great plays by seeing which tickers are moving within strong sectors. [cite: 34]" />
        <StepCard number="04" title="Look for setups with confluences" description="The more confluences (strat, EMAs, trendlines), the more likely the trade works. [cite: 35]" />
        <StepCard number="05" title="Check option contracts" description="Ensure you have favorable Greeks, IV, volume, and open interest. [cite: 36]" />
        <StepCard number="06" title="Market look back" description="Analyze what moved the market on the daily/weekly to gauge direction. [cite: 37]" />
        <StepCard number="07" title="Look for catalysts" description="Check for Earnings, CPI, Fed Rates, or company events. [cite: 38]" />
        <StepCard number="08" title="Review rules & mentally prepare" description="Rewrite your rules and use morning meditation to stay focused. [cite: 39]" />
      </div>
    </div>
  </section>

  <section class="section" id="journaling" style="background: var(--bg-secondary);">
    <div class="container">
      <h2>Journaling</h2>
      <div class="grid grid-3">
        <div class="card journal-card">
          <Icon name="lucide:pencil-line" />
          <h4>Daily Reflection</h4>
          <p>Explain what you did well and what you did poorly. [cite: 59]</p>
        </div>
        <div class="card journal-card">
          <Icon name="lucide:crosshair" />
          <h4>Track Your Trades</h4>
          <p>Document every trade you take. What was your reasoning? [cite: 60]</p>
        </div>
        <div class="card journal-card">
          <Icon name="lucide:scale" />
          <h4>Compare to Ideal</h4>
          <p>Compare your actual entry and exit to the IDEAL trade. [cite: 61]</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  [data-icon] {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--accent-primary);
    filter: drop-shadow(0 0 8px rgba(108, 99, 255, 0.4));
    margin: 0 auto 1rem;
    display: block;
  }
  /* ... rest of your existing CSS ... */
</style>