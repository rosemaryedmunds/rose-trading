---
import Layout from '../layouts/Layout.astro';
import StepCard from '../components/StepCard.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Trading Guides">
  <section class="hero">
    <div class="container">
      <h1>Trading Guides</h1>
      <p class="intro">
        Essential guides to help you prepare for the market, develop a study plan, and maintain a trading journal. 
      </p>
    </div>
  </section>

  <section class="section" style="background: var(--bg-secondary);">
    <div class="container" style="max-width: 900px;">
      <div class="guides-nav">
        <a href="#preparing" class="guide-nav-btn">Preparing for the Market</a>
        <a href="#study-plan" class="guide-nav-btn">Study Plan</a>
        <a href="#journaling" class="guide-nav-btn">Journaling</a>
      </div>
    </div>
  </section>

  <section class="section" id="preparing">
    <div class="container">
      <h2>Preparing for the Market</h2>
      <div class="grid grid-2">
        <StepCard 
          number="01"
          title="Chart Indices & Futures"
          description="Find the direction of where the market is going using ES, SPY, NQ, etc. [cite: 32]"
        />
        <StepCard 
          number="08"
          title="Review Rules"
          description="Rewrite your rules to ensure you follow them. [cite: 39]"
        />
      </div>
    </div>
  </section>

  <section class="section" id="study-plan" style="background: var(--bg-secondary);">
    <div class="container">
      <h2>Study Plan</h2>
      <div class="study-grid">
        <div class="card">
          <Icon name="lucide:bar-chart-2" />
          <h3 style="color: var(--accent-primary); text-align: center;">#theStrat</h3>
          <ul class="link-list">
            <li><a href="https://www.youtube.com/@SaraStratSniper/playlists" target="_blank">→ Sara Strat Sniper Playlists [cite: 45]</a></li>
            <li><a href="https://www.youtube.com/playlist?list=PL8FT63xUyCPPSq2qJdgVDBbxJU6CRW2_X" target="_blank">→ Adex Beginner's Guide [cite: 46]</a></li>
          </ul>
        </div>

        <div class="card">
          <Icon name="lucide:line-chart" />
          <h3 style="color: var(--accent-primary); text-align: center;">ICT</h3>
          <ul class="link-list">
            <li><a href="https://www.youtube.com/playlist?list=PLVgHx4Z63pabb9rl1nyG58TG8PG8yzuao" target="_blank">→ 2016 Mentorship Series [cite: 51]</a></li>
            <li><a href="https://www.youtube.com/playlist?list=PLVgHx4Z63paYiFGQ56PjTF1PGePL3r69s" target="_blank">→ 2022 Mentorship [cite: 52]</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  [data-icon] {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--accent-primary);
    filter: drop-shadow(0 0 8px rgba(108, 99, 255, 0.4));
    margin: 0 auto 1rem;
    display: block;
  }
  .link-list {
    list-style: none;
    padding: 0;
    margin-top: 1rem;
  }
  .link-list li { margin-bottom: 0.5rem; }
  .link-list a { color: var(--text-secondary); text-decoration: none; }
  .link-list a:hover { color: var(--accent-primary); }
</style>