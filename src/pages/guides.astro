---
import Layout from '../layouts/Layout.astro';
import StepCard from '../components/StepCard.astro';
import { Icon } from 'astro-icon/components'; [cite: 28]
---

<section class="section" id="journaling">
  <div class="container">
    <h2>Journaling</h2> [cite: 58]
    <div class="grid grid-3">
      <div class="card journal-card">
        <Icon name="lucide:pencil-line" /> [cite: 59]
        <h4>Daily Reflection</h4>
      </div>

      <div class="card journal-card">
        <Icon name="lucide:crosshair" /> [cite: 60]
        <h4>Track Your Trades</h4>
      </div>

      <div class="card journal-card">
        <Icon name="lucide:scale" /> [cite: 60]
        <h4>Compare to Ideal</h4>
      </div>

      <div class="card journal-card">
        <Icon name="lucide:check-circle" /> [cite: 61]
        <h4>Wins & Mistakes</h4>
      </div>

      <div class="card journal-card">
        <Icon name="lucide:refresh-cw" /> [cite: 63]
        <h4>Future Planning</h4>
      </div>

      <div class="card journal-card">
        <Icon name="lucide:bar-chart-3" /> [cite: 64]
        <h4>Visual Documentation</h4>
      </div>
    </div>
  </div>
</section>

<style>
  [data-icon] {
    width: 3rem;
    height: 3rem;
    color: var(--accent-primary);
    filter: drop-shadow(0 0 8px rgba(108, 99, 255, 0.4));
    margin-bottom: 1rem;
  }
  /* ... rest of styles ... */
</style>