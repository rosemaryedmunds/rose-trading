---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Contact">
  <section class="section">
    <div class="container">
      <h1 style="text-align: center; margin-bottom: 2rem;">Contact</h1>
      
      <div class="card" style="max-width: 800px; margin: 0 auto; text-align: center;">
        <h2 style="color: var(--accent-primary); margin-bottom: 1.5rem;">Join our Discord Community</h2>
        <p style="font-size: 1.125rem; margin-bottom: 2rem;">
          Learning to trade by yourself can sometimes make you feel lost. [cite: 18] If you'd like to be part of a 
          community that focuses on discipline, education, live trading and overall a fun environment, 
          please join us. [cite: 19]
        </p>
        <a href="https://whop.com/adextrades/?d2c=true&directPlanId=plan_0S7UBXkzD2JTf&pass=prod_Qq8PUMzDnOp6O&a=user1ec11086429" 
           class="btn" 
           target="_blank" 
           rel="noopener noreferrer">
          Join Discord Community
        </a>
      </div>

      <div style="max-width: 800px; margin: 3rem auto 0;">
        <h3 style="text-align: center; margin-bottom: 2rem;">Connect With Me</h3>
  
        <div class="grid grid-3" style="gap: 1.5rem;">
          <a href="https://tr.ee/HzQr7BRA4M" target="_blank" rel="noopener noreferrer" class="social-card card">
            <div class="social-icon">
              <Icon name="lucide:youtube" />
            </div>
            <h4 style="color: var(--accent-primary); margin-bottom: 0.5rem;">YouTube</h4>
            <p style="margin: 0;">Watch my trading videos and tutorials</p>
          </a>
          
          <a href="https://x.com/funsized_rose" target="_blank" rel="noopener noreferrer" class="social-card card">
            <div class="social-icon">
              <Icon name="lucide:twitter" />
            </div>
            <h4 style="color: var(--accent-primary); margin-bottom: 0.5rem;">X (Twitter)</h4>
            <p style="margin: 0;">Follow for daily market updates</p>
          </a>
          
          <a href="https://tr.ee/AtSEFYmhEe" target="_blank" rel="noopener noreferrer" class="social-card card">
            <div class="social-icon">
              <Icon name="lucide:calendar" />
            </div>
            <h4 style="color: var(--accent-primary); margin-bottom: 0.5rem;">Schedule a Call</h4>
            <p style="margin: 0;">Book time to chat via Calendly</p>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  h1 {
    font-size: 3rem;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .social-card {
    text-align: center;
    text-decoration: none;
    display: block;
    transition: all 0.3s ease;
  }
  
  .social-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 32px rgba(108, 99, 255, 0.2);
  }

  [data-icon] {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--accent-primary);
    filter: drop-shadow(0 0 8px rgba(108, 99, 255, 0.4));
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    h1 { font-size: 2rem; }
  }
</style>